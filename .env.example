# ── Server ────────────────────────────────────────────────────────────────────
# Port for the unified devglide server (default: 7000)
PORT=7000

# ── Voice Transcription ───────────────────────────────────────────────────────
# Provider to use: openai | groq | whisper-cpp | faster-whisper | vllm | local-ai
VOICE_PROVIDER=openai

# Language for transcription (default: auto-detect)
WHISPER_LANGUAGE=auto

# OpenAI Whisper
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# Groq Whisper
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Whisper.cpp (local)
WHISPER_CPP_URL=http://localhost:8080
WHISPER_CPP_MODEL=default

# Faster Whisper (local)
FASTER_WHISPER_URL=http://localhost:8000
FASTER_WHISPER_MODEL=default

# vLLM (local)
VLLM_URL=http://localhost:8000/v1
VLLM_WHISPER_MODEL=default

# LocalAI (local)
LOCAL_AI_URL=http://localhost:8080
LOCAL_AI_WHISPER_MODEL=whisper-1
